{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://resciencelab.github.io/sitewright/schemas/page-brief.schema.json",
  "title": "Sitewright Page Brief",
  "type": "object",
  "required": ["route", "pageType", "title", "description", "h1"],
  "properties": {
    "route": { "type": "string", "pattern": "^/" },
    "pageType": {
      "type": "string",
      "enum": ["home", "product", "use-case", "faq", "glossary", "alternative", "free-tool", "tools-hub", "lp", "private", "docs", "custom"]
    },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "h1": { "type": "string" },
    "primaryKeyword": { "type": "string" },
    "question": { "type": "string", "description": "Exact searched question when pageType is faq." },
    "term": { "type": "string", "description": "Glossary term when pageType is glossary." },
    "definition": { "type": "string", "description": "One-line definition when pageType is glossary." },
    "product": { "type": "string" },
    "audience": { "type": ["string", "array"], "items": { "type": "string" } },
    "intent": { "type": "string" },
    "noindex": { "type": "boolean", "default": false },
    "cta": {
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "href": { "type": "string" }
      },
      "additionalProperties": true
    },
    "facts": { "type": "array", "items": { "type": "string" } },
    "faqs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["question", "answer"],
        "properties": {
          "question": { "type": "string" },
          "answer": { "type": "string" }
        }
      }
    },
    "related": { "type": "array", "items": { "type": "string" } },
    "constraints": { "type": "array", "items": { "type": "string" } },
    "tool": {
      "type": "object",
      "description": "Free tool specification when pageType is free-tool.",
      "properties": {
        "category": {
          "type": "string",
          "enum": ["generator", "converter", "analyzer", "calculator", "previewer", "validator", "other"]
        },
        "input": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "output": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "logic": { "type": "string" },
        "privacy": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
