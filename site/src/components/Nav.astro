---
import { navLinks } from "../lib/navigation";
---

<header class="site-header">
  <nav class="nav container" aria-label="Main navigation" data-nav>
    <a class="brand" href="/" aria-label="Pagewell home">
      <span class="brand__mark" aria-hidden="true">P</span>
      <span>Pagewell</span>
    </a>

    <button
      class="nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="primary-navigation"
      data-nav-toggle
    >
      <span class="nav-toggle__label">Menu</span>
      <span class="nav-toggle__bars" aria-hidden="true">
        <span></span>
        <span></span>
      </span>
    </button>

    <div class="nav-links" id="primary-navigation" data-nav-menu>
      {navLinks.map((link) => <a href={link.href}>{link.label}</a>)}
      <a class="nav-cta" href="#cta">Install</a>
    </div>
  </nav>
</header>

<script>
  document.querySelectorAll("[data-nav]").forEach((nav) => {
    const toggle = nav.querySelector("[data-nav-toggle]");
    const menu = nav.querySelector("[data-nav-menu]");

    if (!(toggle instanceof HTMLButtonElement) || !menu) return;

    toggle.addEventListener("click", () => {
      const isOpen = nav.classList.toggle("is-open");
      toggle.setAttribute("aria-expanded", String(isOpen));
    });

    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        nav.classList.remove("is-open");
        toggle.setAttribute("aria-expanded", "false");
      });
    });
  });
</script>
