---
import CommandCopy from "./CommandCopy.astro";

const proofPoints = ["MIT licensed", "Normal repo code", "No hosted builder", "QA for metadata, schema, and claims"];
---

<section class="section cta-section" id="cta">
  <div class="container cta-card blue-ring">
    <p class="eyebrow">Get started</p>
    <h2 class="display-section">Ship pages from your repo today.</h2>
    <p class="body cta-card__copy">
      Install Pagewell and give your agent the context it needs to generate real pages — metadata, schema, and QA included.
    </p>
    <ul class="cta-proof-list" aria-label="Pagewell proof points">
      {proofPoints.map((point) => <li>{point}</li>)}
    </ul>
    <CommandCopy command="bunx skills add ReScienceLab/pagewell --skill pagewell" note="Installs the Pagewell agent skill via skills.sh." />
  </div>
</section>
