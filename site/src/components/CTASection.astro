---
import CommandCopy from "./CommandCopy.astro";
---

<section class="section cta-section" id="cta">
  <div class="container cta-card blue-ring">
    <p class="eyebrow">Install the workflow</p>
    <h2 class="display-section">Give your agent a page system before the next request.</h2>
    <p class="body cta-card__copy">
      Start with one homepage, use-case page, comparison, or free tool. Pagewell keeps the brief, design rules, stack conventions, QA gates, and discovery updates in the same repo as the code.
    </p>
    <CommandCopy command="bunx skills add ReScienceLab/pagewell --skill pagewell" note="Installs the Pagewell agent skill via skills.sh." />
  </div>
</section>
