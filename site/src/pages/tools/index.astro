---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CommandCopy from "../../components/CommandCopy.astro";
import FAQ from "../../components/FAQ.astro";
import { absoluteUrl } from "../../lib/seo";
import { breadcrumbListSchema, faqPageSchema } from "../../lib/schema";

const entries = await getCollection("tools");
const page = entries.find((e) => e.id === "index");
if (!page) throw new Error("index entry not found");
const { data } = page;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Free Pagewell Tools",
    description: data.description,
    url: absoluteUrl("/tools"),
    hasPart: data.tools.map((tool) => ({
      "@type": "WebApplication",
      name: tool.name,
      applicationCategory: "UtilityApplication",
      url: absoluteUrl(tool.href),
      description: tool.description,
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
    })),
  },
  breadcrumbListSchema([
    { name: "Home", item: "/" },
    { name: "Tools", item: "/tools" },
  ]),
  faqPageSchema(data.faqs ?? []),
];
---

<BaseLayout
  title={data.title}
  description={data.description}
  canonical="/tools"
  jsonLd={jsonLd}
>
  <section class="section generated-hero">
    <div class="container generated-hero__inner">
      <p class="eyebrow">{data.heroEyebrow}</p>
      <h1 class="display-section">{data.heroH1}</h1>
      <p class="body generated-hero__lede">{data.heroLede}</p>
    </div>
  </section>

  <section class="section generated-section">
    <div class="container generated-section__inner">
      <div class="section-heading section-heading--left">
        <p class="eyebrow">{data.sections[0].eyebrow}</p>
        <h2 class="display-section">{data.sections[0].heading}</h2>
        <p class="body section-lede">{data.sections[0].lede}</p>
      </div>
      <div class="generated-card-grid">
        {data.tools.map((tool) => (
          <a class="card generated-card" href={tool.href}>
            <p class="kicker">{tool.category}</p>
            <h3>{tool.name}</h3>
            <p>{tool.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section generated-section">
    <div class="container split">
      <div class="section-heading section-heading--left">
        <p class="eyebrow">{data.sections[1].eyebrow}</p>
        <h2 class="display-section">{data.sections[1].heading}</h2>
        <p class="body section-lede">{data.sections[1].lede}</p>
      </div>
      <CommandCopy command="bunx skills add ReScienceLab/pagewell --skill pagewell" note="Then ask your coding agent to validate PAGEWELL.md, llms.txt, sitemap behavior, and generated page metadata." />
    </div>
  </section>

  <FAQ items={data.faqs} />
</BaseLayout>
