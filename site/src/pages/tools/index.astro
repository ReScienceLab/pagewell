---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CommandCopy from "../../components/CommandCopy.astro";
import FAQ from "../../components/FAQ.astro";
import { absoluteUrl } from "../../lib/seo";
import { breadcrumbListSchema, faqPageSchema } from "../../lib/schema";

const tools = [
  {
    name: "Page Brief Generator",
    href: "/tools/page-brief-generator",
    category: "Page planning",
    description:
      "Turn a keyword, audience, product, and CTA into a copyable Pagewell-ready markdown brief before an agent edits the repo.",
  },
  {
    name: "AI Landing Page QA Grader",
    href: "/tools/ai-landing-page-qa-grader",
    category: "Page QA",
    description:
      "Grade generated page copy for genericness, unsupported claims, CTA clarity, proof signals, metadata hints, and QA gaps."
  },
  {
    name: "Metadata + Schema Checker",
    href: "/tools/metadata-schema-checker",
    category: "SEO preflight",
    description:
      "Check pasted HTML for title, meta description, canonical, Open Graph, Twitter tags, H1 count, and JSON-LD parseability.",
  },
  {
    name: "llms.txt Validator",
    href: "/tools/llms-txt-validator",
    category: "AI discovery",
    description:
      "Paste an llms.txt draft and check structure, absolute URLs, private content risks, length, and hype language in the browser.",
  },
  {
    name: "PAGEWELL.md Validator",
    href: "/tools/pagewell-context-validator",
    category: "Agent context",
    description:
      "Validate a PAGEWELL.md draft for product facts, claim rules, site conventions, route taxonomy, page patterns, and QA sections.",
  },
];

const faqs = [
  {
    question: "Are Pagewell tools free to use?",
    answer:
      "Yes. The public tools on this hub provide first value without signup and run client-side unless a page explicitly says otherwise.",
  },
  {
    question: "Do these tools replace the Pagewell workflow?",
    answer:
      "No. They are quick generators and checks for specific artifacts. Pagewell still uses PAGEWELL.md, DESIGN.md, page briefs, adapters, and QA playbooks before it changes repo files.",
  },
  {
    question: "Can Pagewell generate tools like these in another repo?",
    answer:
      "Yes. Pagewell includes a free-tool workflow for no-signup utilities with crawlable SEO shells, working input/output behavior, schema, FAQs, and related links.",
  },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Free Pagewell Tools",
    description: "Free browser-based tools for Pagewell page briefs, landing-page QA, metadata, schema, context, and AI discovery files.",
    url: absoluteUrl("/tools"),
    hasPart: tools.map((tool) => ({
      "@type": "WebApplication",
      name: tool.name,
      applicationCategory: "UtilityApplication",
      url: absoluteUrl(tool.href),
      description: tool.description,
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
    })),
  },
  breadcrumbListSchema([
    { name: "Home", item: "/" },
    { name: "Tools", item: "/tools" },
  ]),
  faqPageSchema(faqs),
];
---

<BaseLayout
  title="Free Pagewell Tools for Pages as Code"
  description="Free browser-based Pagewell tools for page briefs, AI landing page QA, metadata, schema, PAGEWELL.md context, and llms.txt. No signup required."
  canonical="/tools"
  jsonLd={jsonLd}
>
  <section class="section generated-hero">
    <div class="container generated-hero__inner">
      <p class="eyebrow">Free tools</p>
      <h1 class="display-section">Free Pagewell tools for pages as code.</h1>
      <p class="body generated-hero__lede">
        Generate a brief, grade generated copy, check metadata and schema, then validate the context and discovery files coding agents rely on before they ship page work in your repo.
      </p>
    </div>
  </section>

  <section class="section generated-section">
    <div class="container generated-section__inner">
      <div class="section-heading section-heading--left">
        <p class="eyebrow">Tool hub</p>
        <h2 class="display-section">Start with a working utility, not a signup wall.</h2>
        <p class="body section-lede">
          Each tool returns a concrete browser-only result and fits a simple workflow: plan the page, grade the draft, check metadata, validate context, and keep AI discovery files factual.
        </p>
      </div>
      <div class="generated-card-grid">
        {tools.map((tool) => (
          <a class="card generated-card" href={tool.href}>
            <p class="kicker">{tool.category}</p>
            <h3>{tool.name}</h3>
            <p>{tool.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section generated-section">
    <div class="container split">
      <div class="section-heading section-heading--left">
        <p class="eyebrow">Repo workflow</p>
        <h2 class="display-section">Use the checks in a real site repo.</h2>
        <p class="body section-lede">
          Install Pagewell when you want an agent to generate or maintain pages, update discovery files, and run QA against product facts and design rules.
        </p>
      </div>
      <CommandCopy command="bunx skills add ReScienceLab/pagewell --skill pagewell" note="Then ask your coding agent to validate PAGEWELL.md, llms.txt, sitemap behavior, and generated page metadata." />
    </div>
  </section>

  <FAQ items={faqs} />
</BaseLayout>
