---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CodeWindow from "../../components/CodeWindow.astro";
import CommandCopy from "../../components/CommandCopy.astro";
import FAQ from "../../components/FAQ.astro";
import { absoluteUrl } from "../../lib/seo";
import { breadcrumbListSchema, faqPageSchema } from "../../lib/schema";

const entries = await getCollection("tool-pages");
const page = entries.find((e) => e.id === "pagewell-setup-checklist");
if (!page) throw new Error("pagewell-setup-checklist entry not found");
const { data } = page;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "Pagewell Setup Checklist",
    description: data.description,
    url: absoluteUrl(data.canonical),
    applicationCategory: "DeveloperApplication",
    operatingSystem: "Any",
    offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  },
  breadcrumbListSchema([
    { name: "Home", item: "/" },
    { name: "Tools", item: "/tools" },
    { name: "Pagewell Setup Checklist", item: data.canonical },
  ]),
  faqPageSchema(data.faqs ?? []),
];
---

<BaseLayout title={data.title} description={data.description} canonical={data.canonical} jsonLd={jsonLd}>
  <section class="section generated-hero">
    <div class="container generated-hero__inner">
      <p class="eyebrow">{data.heroEyebrow}</p>
      <h1 class="display-section">{data.heroH1}</h1>
      <p class="body generated-hero__lede">{data.heroLede}</p>
      <div class="generated-actions">
        <a class="pill" href={data.primaryCtaHref}>{data.primaryCtaLabel}</a>
        <a class="pill pill--ghost" href="/tools">View all tools</a>
      </div>
      <ul class="tool-proof-list" aria-label="Tool privacy and access">
        {data.heroProof.map((p) => <li>{p}</li>)}
      </ul>
    </div>
  </section>

  <section class="generated-band" id="tool">
    <div class="container tool-panel tool-panel--wide" data-setup-tool>
      <div class="tool-card">
        <form class="tool-form" data-setup-form>
          <label class="tool-field" for="setup-framework">
            Framework
            <select id="setup-framework" data-setup-field="framework">
              <option value="astro">Astro</option>
              <option value="nextjs">Next.js</option>
              <option value="static">Static HTML</option>
              <option value="other">Other / Custom</option>
            </select>
          </label>
          <label class="tool-field" for="setup-has-design">
            Do you have DESIGN.md or equivalent design rules?
            <select id="setup-has-design" data-setup-field="hasDesign">
              <option value="no">No — need to create one</option>
              <option value="partial">Partial — needs cleanup</option>
              <option value="yes">Yes — ready to use</option>
            </select>
          </label>
          <label class="tool-field" for="setup-routes">
            How many page routes exist today?
            <select id="setup-routes" data-setup-field="routes">
              <option value="few">1–5 pages</option>
              <option value="some">6–20 pages</option>
              <option value="many">21+ pages</option>
            </select>
          </label>
          <label class="tool-field" for="setup-product-facts">
            Do you have documented product facts and claims?
            <select id="setup-product-facts" data-setup-field="facts">
              <option value="no">No — need to collect them</option>
              <option value="some">Some — scattered in docs</option>
              <option value="yes">Yes — centralized and reviewed</option>
            </select>
          </label>
          <label class="tool-field" for="setup-team">
            Who will review generated pages?
            <select id="setup-team" data-setup-field="team">
              <option value="solo">Just me</option>
              <option value="small">1–2 others</option>
              <option value="team">3+ person workflow</option>
            </select>
          </label>
          <div class="tool-actions">
            <button class="pill" type="submit">Generate checklist</button>
            <button class="pill pill--ghost" type="button" data-reset-setup>Reset</button>
          </div>
          <p class="tool-message" data-setup-message>Runs locally in your browser. No signup and no upload.</p>
        </form>
      </div>
      <div class="tool-card">
        <label for="setup-output">Setup checklist</label>
        <output id="setup-output" class="tool-output" data-setup-output>Answer the questions and click “Generate checklist” to get your personalized setup plan.</output>
        <div class="tool-actions">
          <button class="pill pill--ghost" type="button" data-copy-setup>Copy checklist</button>
          <button class="pill pill--ghost" type="button" data-download-setup>Download .md</button>
        </div>
      </div>
    </div>
  </section>

  {data.sections.map((section) => (
    <section class="section generated-section">
      <div class="container generated-section__inner">
        <div class="section-heading section-heading--left">
          <p class="eyebrow">{section.eyebrow}</p>
          <h2 class="display-section">{section.heading}</h2>
          {section.lede && <p class="body section-lede">{section.lede}</p>}
        </div>
        {section.cards && (
          <div class="generated-card-grid">
            {section.cards.map((card) => (
              <article class="card generated-card">
                {card.kicker && <p class="kicker">{card.kicker}</p>}
                <h3>{card.title}</h3>
                <p>{card.text}</p>
              </article>
            ))}
          </div>
        )}
        {section.codeLines && <CodeWindow title={section.codeTitle ?? "example"} lines={section.codeLines} />}
      </div>
    </section>
  ))}

  {data.relatedTools && (
    <section class="section generated-section">
      <div class="container generated-section__inner">
        <div class="section-heading section-heading--left">
          <p class="eyebrow">Related tools</p>
          <h2 class="display-section">Validate, brief, then build.</h2>
        </div>
        <div class="generated-card-grid generated-card-grid--related">
          {data.relatedTools.map((t) => (
            <a class="card generated-card generated-link-card" href={t.href}>
              <p class="kicker">{t.kicker}</p>
              <h3>{t.label}</h3>
              <p>{t.text}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {data.finalCta && (
    <section class="section generated-section">
      <div class="container generated-section__inner">
        <div class="section-heading section-heading--left">
          <p class="eyebrow">{data.finalCta.eyebrow}</p>
          <h2 class="display-section">{data.finalCta.heading}</h2>
          <p class="body section-lede">{data.finalCta.lede}</p>
        </div>
        <CommandCopy command={data.finalCta.command} note={data.finalCta.note} />
      </div>
    </section>
  )}

  <FAQ items={data.faqs ?? []} />
</BaseLayout>

<script is:inline>
  const form = document.querySelector("[data-setup-form]");
  const output = document.querySelector("[data-setup-output]");
  const message = document.querySelector("[data-setup-message]");

  function val(name) {
    const el = document.querySelector(`[data-setup-field="${name}"]`);
    return el?.value || "";
  }

  function generateChecklist(event) {
    event.preventDefault();
    const framework = val("framework");
    const hasDesign = val("hasDesign");
    const routes = val("routes");
    const facts = val("facts");
    const team = val("team");

    const frameworkNames = { astro: "Astro", nextjs: "Next.js", static: "Static HTML", other: "Custom" };
    const fw = frameworkNames[framework] || framework;

    const items = [];
    items.push("[ ] Install Pagewell: bunx skills add ReScienceLab/pagewell --skill pagewell");

    if (hasDesign === "no") {
      items.push("[ ] Create DESIGN.md from your existing visual rules (colors, typography, components, spacing)");
      items.push("[ ] Run: bun run lint:design (if available) to check against the Google DESIGN.md spec");
    } else if (hasDesign === "partial") {
      items.push("[ ] Clean up and complete DESIGN.md with missing visual rules");
      items.push("[ ] Run: bun run lint:design to validate");
    } else {
      items.push("[ ] Verify DESIGN.md is current and references the correct component paths");
    }

    items.push(`[ ] Run discover-site to inspect your ${fw} repo`);
    items.push("[ ] Review generated PAGEWELL.md for accuracy");

    if (facts === "no") {
      items.push("[ ] Collect product facts, supported claims, and prohibited claims from README, docs, and team input");
    } else if (facts === "some") {
      items.push("[ ] Consolidate scattered product facts and claims into PAGEWELL.md");
    }

    items.push("[ ] Add route taxonomy for existing and planned page types");
    items.push("[ ] Document page and component patterns");
    items.push("[ ] Add generation rules and anti-generic QA rules");
    items.push("[ ] Add QA rules for metadata, schema, claims, and discovery files");

    if (routes === "many") {
      items.push("[ ] Inventory existing routes before adding new ones to avoid duplication");
    }

    if (team === "team") {
      items.push("[ ] Document review workflow: who checks generated diffs, who approves claims");
    }

    items.push("[ ] Run a test page generation and verify the diff");
    items.push("[ ] Check metadata, schema, canonical, and H1 in the generated route");
    items.push("[ ] Update sitemap, robots, and llms.txt if the test page is indexable");
    items.push("[ ] Schedule a monthly PAGEWELL.md review to keep facts and claims current");

    const starter = [
      "",
      "## Starter PAGEWELL.md sections",
      "- Product facts",
      "- Supported claims (with sources)",
      "- Prohibited or unknown claims",
      `- Site implementation (${fw})`,
      "- Route taxonomy",
      "- Page and component patterns",
      "- Generation rules",
      "- Anti-generic QA rules",
      "- QA rules",
      "",
      "## Starter DESIGN.md sections",
      "- Colors",
      "- Typography",
      "- Spacing",
      "- Components",
      "- Layout rules",
      "- Do's and don'ts",
    ];

    const lines = [
      "# Pagewell Setup Checklist",
      `Generated for: ${fw} / ${routes} routes / ${team} review workflow`,
      "",
      ...items,
      ...starter,
    ];

    output.textContent = lines.join("\n");
    message.textContent = "Checklist generated.";
  }

  form?.addEventListener("submit", generateChecklist);

  document.querySelector("[data-reset-setup]")?.addEventListener("click", () => {
    form?.reset();
    output.textContent = "Answer the questions and click “Generate checklist” to get your personalized setup plan.";
    message.textContent = "Defaults restored.";
  });

  document.querySelector("[data-copy-setup]")?.addEventListener("click", async () => {
    const text = output?.textContent || "";
    if (!text || text.startsWith("Answer")) return;
    await navigator.clipboard.writeText(text);
    message.textContent = "Checklist copied.";
  });

  document.querySelector("[data-download-setup]")?.addEventListener("click", () => {
    const text = output?.textContent || "";
    if (!text || text.startsWith("Answer")) return;
    const blob = new Blob([text], { type: "text/markdown" });
    const url = URL.createObjectURL(blob);
    const link = document.createElement("a");
    link.href = url;
    link.download = "pagewell-setup-checklist.md";
    link.click();
    URL.revokeObjectURL(url);
    message.textContent = "Downloaded pagewell-setup-checklist.md";
  });
</script>
