---
import { getCollection } from "astro:content";
import GeneratedPage from "../../components/GeneratedPage.astro";
import { breadcrumbListSchema, faqPageSchema } from "../../lib/schema";

const entries = await getCollection("faq");
const page = entries.find((e) => e.id === "does-pagewell-work-with-nextjs");
if (!page) throw new Error("does-pagewell-work-with-nextjs entry not found");
const { data } = page;

const jsonLd = [
  breadcrumbListSchema([
    { name: "Home", item: "/" },
    { name: "FAQ", item: "/faq/does-pagewell-work-with-nextjs" },
  ]),
  faqPageSchema(data.faqs ?? []),
];
---

<GeneratedPage {...data} jsonLd={jsonLd} />
