---
import { getCollection } from "astro:content";
import GeneratedPage from "../../components/GeneratedPage.astro";
import { breadcrumbListSchema, faqPageSchema } from "../../lib/schema";

const entries = await getCollection("faq");
const page = entries.find((e) => e.id === "what-is-pagewell-md");
if (!page) throw new Error("what-is-pagewell-md entry not found");
const { data } = page;

const jsonLd = [
  breadcrumbListSchema([
    { name: "Home", item: "/" },
    { name: "FAQ", item: "/faq/what-is-pagewell-md" },
  ]),
  faqPageSchema(data.faqs ?? []),
];
---

<GeneratedPage {...data} jsonLd={jsonLd} />
