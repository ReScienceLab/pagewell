---
import { getCollection } from "astro:content";
import GeneratedPage from "../../components/GeneratedPage.astro";
import { breadcrumbListSchema, faqPageSchema } from "../../lib/schema";

const entries = await getCollection("faq");
const page = entries.find((e) => e.id === "can-i-use-pagewell-with-astro");
if (!page) throw new Error("can-i-use-pagewell-with-astro entry not found");
const { data } = page;

const jsonLd = [
  breadcrumbListSchema([
    { name: "Home", item: "/" },
    { name: "FAQ", item: "/faq/can-i-use-pagewell-with-astro" },
  ]),
  faqPageSchema(data.faqs ?? []),
];
---

<GeneratedPage {...data} jsonLd={jsonLd} />
