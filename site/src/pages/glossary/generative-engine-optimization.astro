---
import { getCollection } from "astro:content";
import GeneratedPage from "../../components/GeneratedPage.astro";
import { articleSchema, breadcrumbListSchema, definedTermSchema } from "../../lib/schema";

const entries = await getCollection("glossary");
const page = entries.find((e) => e.id === "generative-engine-optimization");
if (!page) throw new Error("generative-engine-optimization entry not found");
const { data } = page;

const jsonLd = [
  definedTermSchema({
    name: "Generative engine optimization",
    alternateName: "GEO",
    description:
      "Generative engine optimization is the practice of making content easier for AI answer engines to understand, cite, and route users from.",
    url: data.canonical,
  }),
  articleSchema({
    headline: data.title,
    description: data.description,
    url: data.canonical,
    keywords: ["generative engine optimization", "GEO", "AI SEO"],
  }),
  breadcrumbListSchema([
    { name: "Home", item: "/" },
    { name: "Glossary", item: "/glossary/generative-engine-optimization" },
  ]),
];
---

<GeneratedPage {...data} jsonLd={jsonLd} />
