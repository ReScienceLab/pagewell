---
import GeneratedPage from "../../components/GeneratedPage.astro";
import { breadcrumbListSchema } from "../../lib/schema";

const definedTermSchema = {
  "@context": "https://schema.org",
  "@type": "DefinedTerm",
  name: "Generative engine optimization",
  alternateName: "GEO",
  description:
    "Generative engine optimization is the practice of making content easier for AI answer engines to understand, cite, and route users from.",
  url: "https://pagewell.dev/glossary/generative-engine-optimization",
};

const jsonLd = [
  definedTermSchema,
  breadcrumbListSchema([
    { name: "Home", item: "/" },
    { name: "Glossary", item: "/glossary/generative-engine-optimization" },
  ]),
];
---

<GeneratedPage
  title="Generative Engine Optimization - Definition & Examples"
  description="Generative engine optimization, or GEO, helps AI answer engines understand, cite, and route users from useful web pages."
  canonical="/glossary/generative-engine-optimization"
  eyebrow="Glossary"
  h1="What is generative engine optimization?"
  lede="Generative engine optimization, or GEO, is the practice of making web content easier for AI answer engines to understand, cite, and route qualified users from."
  primaryCta={{ label: "Generate GEO pages as code", href: "/use-cases/generate-seo-pages-as-code" }}
  secondaryCta={{ label: "Install Pagewell", href: "/products/pagewell" }}
  highlights={[
    {
      kicker: "Definition",
      title: "Answer-ready content",
      text: "GEO favors factual, clearly structured pages that directly answer questions and expose stable product facts.",
    },
    {
      kicker: "Mechanism",
      title: "Readable by humans and machines",
      text: "Headings, direct answers, schema, examples, and internal links help both readers and AI systems understand the page.",
    },
    {
      kicker: "Pagewell angle",
      title: "Context before generation",
      text: "Pagewell uses PAGEWELL.md and DESIGN.md so GEO pages are factual, specific, and native to the repo.",
    },
  ]}
  sections={[
    {
      eyebrow: "Expanded explanation",
      heading: "GEO is not just writing more content for AI crawlers.",
      body:
        "A useful GEO page should satisfy a narrow intent, state the answer plainly, include concrete examples, and avoid unsupported claims. The goal is to be easy to quote without becoming thin or generic.",
      bullets: [
        "Use stable terminology and direct answers near the top of the page.",
        "Connect definitions to product workflows only when the connection is real.",
        "Add schema only when the visible content supports it.",
        "Keep claims grounded in a source of truth such as PAGEWELL.md.",
      ],
    },
    {
      eyebrow: "Example",
      heading: "A Pagewell GEO page starts with a brief and a context file.",
      codeTitle: "geo page ingredients",
      codeLines: [
        "PAGEWELL.md: product facts, route taxonomy, page patterns, claims",
        "DESIGN.md: visual identity and component rules",
        "brief: query, intent, audience, CTA, constraints",
        "playbook: required coverage for the page type",
        "QA: metadata, schema, claims, genericness, discovery",
      ],
    },
    {
      eyebrow: "Related terms",
      heading: "Where GEO connects to Pagewell page types.",
      cards: [
        {
          kicker: "FAQ",
          title: "Exact question pages",
          text: "FAQ pages answer one searched question directly and can include FAQPage schema when visible content matches.",
        },
        {
          kicker: "Glossary",
          title: "Definition pages",
          text: "Glossary pages define one term clearly, provide an example, and link into relevant product or use-case routes.",
        },
        {
          kicker: "Free tools",
          title: "Utility pages",
          text: "Free tools provide immediate value without signup and can earn useful search and citation visibility.",
        },
      ],
    },
  ]}
  related={[
    { label: "Generate SEO pages as code", href: "/use-cases/generate-seo-pages-as-code", text: "Apply GEO coverage to repo-native pages." },
    { label: "llms.txt validator", href: "/tools/llms-txt-validator", text: "Check an AI discovery file with a no-signup tool." },
    { label: "Set up Pagewell", href: "/docs/setup-pagewell", text: "Create PAGEWELL.md before generating topic clusters." },
  ]}
  jsonLd={jsonLd}
  finalCta={{
    eyebrow: "Generate GEO pages",
    heading: "Ready to generate GEO pages as code?",
    copy: "Install Pagewell and create answer-ready glossary and FAQ pages with grounded claims and proper schema.",
  }}
/>
