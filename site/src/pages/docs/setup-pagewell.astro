---
import { getCollection } from "astro:content";
import GeneratedPage from "../../components/GeneratedPage.astro";
import { breadcrumbListSchema, faqPageSchema } from "../../lib/schema";

const entries = await getCollection("docs");
const page = entries.find((e) => e.id === "setup-pagewell");
if (!page) throw new Error("setup-pagewell entry not found");
const { data } = page;

const jsonLd = [
  breadcrumbListSchema([
    { name: "Home", item: "/" },
    { name: "Docs", item: "/docs/setup-pagewell" },
  ]),
  faqPageSchema(data.faqs ?? []),
];
---

<GeneratedPage {...data} jsonLd={jsonLd} />
