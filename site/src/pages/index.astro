---
import { getCollection } from "astro:content";
import AnswerBlock from "../components/AnswerBlock.astro";
import ArtifactTable from "../components/ArtifactTable.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import CodeWindow from "../components/CodeWindow.astro";
import CTASection from "../components/CTASection.astro";
import CommandCopy from "../components/CommandCopy.astro";
import FAQ from "../components/FAQ.astro";
import HeroWordmark from "../components/HeroWordmark.astro";
import PageMeta from "../components/PageMeta.astro";
import PageTypeGrid from "../components/PageTypeGrid.astro";
import Pipeline from "../components/Pipeline.astro";
import { faqPageSchema, organizationSchema, softwareApplicationSchema, websiteSchema } from "../lib/schema";

const entries = await getCollection("home");
const page = entries.find((e) => e.id === "index");
if (!page) throw new Error("index entry not found");
const { data } = page;

const jsonLd = [websiteSchema(), organizationSchema(), softwareApplicationSchema(), faqPageSchema(data.faqItems)];
---

<BaseLayout title={data.title} description={data.description} canonical="/" jsonLd={jsonLd}>
  <section class="hero section">
    <div class="container hero__inner">
      <p class="eyebrow">{data.heroEyebrow}</p>
      <HeroWordmark />

      <div class="hero__copy">
        <h1 class="display-section">{data.heroH1}</h1>
        <p class="body hero__description">{data.heroDescription}</p>
        <div class="hero__actions">
          <CommandCopy command={data.primaryCtaCommand} />
          <a class="pill pill--ghost" href={data.secondaryCtaHref}>{data.secondaryCtaLabel}</a>
        </div>
        <PageMeta />
        <ul class="hero-proof" aria-label="Pagewell proof points">
          {data.heroProof.map((point) => <li>{point}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <AnswerBlock text="Pagewell is a repo-native skill pack for coding agents that generates, checks, and maintains SEO/GEO pages as normal code inside an existing website repo. It uses PAGEWELL.md, DESIGN.md, page-type playbooks, adapters, and QA gates so page work stays reviewable, factual, and discovery-ready." />

  <Pipeline />

  <section class="section" id="generates">
    <div class="container generates__grid">
      <div class="section-heading section-heading--left">
        <p class="eyebrow">{data.generatesSection.eyebrow}</p>
        <h2 class="display-section">{data.generatesSection.heading}</h2>
        <p class="body section-lede">{data.generatesSection.lede}</p>
      </div>
      <ArtifactTable />
    </div>
    <div class="container">
      <PageTypeGrid />
    </div>
  </section>

  <section class="section" id="stack">
    <div class="container split">
      <div class="section-heading section-heading--left">
        <p class="eyebrow">{data.stackSection.eyebrow}</p>
        <h2 class="display-section">{data.stackSection.heading}</h2>
        <p class="body section-lede">{data.stackSection.lede}</p>
        <div class="link-row">
          <a href="https://github.com/ReScienceLab/pagewell/blob/main/PAGEWELL.md">PAGEWELL.md</a>
          <a href="https://github.com/ReScienceLab/pagewell/blob/main/DESIGN.md">DESIGN.md</a>
        </div>
      </div>
      <CodeWindow title="supported adapters" lines={data.stackSection.stackLines} />
    </div>
  </section>

  <section class="section design-section" id="design">
    <div class="container split split--reverse">
      <CodeWindow title="visual contract" lines={data.designSection.designLines} />
      <div class="section-heading section-heading--left">
        <p class="eyebrow">{data.designSection.eyebrow}</p>
        <h2 class="display-section">{data.designSection.heading}</h2>
        <p class="body section-lede">{data.designSection.lede}</p>
      </div>
    </div>
  </section>

  <section class="section qa-section" id="qa">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">{data.qaSection.eyebrow}</p>
        <h2 class="display-section">{data.qaSection.heading}</h2>
        <p class="body section-lede">{data.qaSection.lede}</p>
      </div>
      <div class="qa-grid">
        {data.qaSection.items.map((item) => (
          <article class="card qa-card">
            <p class="kicker">QA gate</p>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <FAQ items={data.faqItems} />
  <CTASection />
</BaseLayout>
