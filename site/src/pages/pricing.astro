---
import { getCollection } from "astro:content";
import GeneratedPage from "../components/GeneratedPage.astro";
import { breadcrumbListSchema, faqPageSchema, softwareApplicationSchema } from "../lib/schema";

const entries = await getCollection("pages");
const page = entries.find((e) => e.id === "pricing");
if (!page) throw new Error("pricing entry not found");
const { data } = page;

const jsonLd = [
  softwareApplicationSchema(),
  breadcrumbListSchema([
    { name: "Home", item: "/" },
    { name: "Pricing", item: "/pricing" },
  ]),
  faqPageSchema(data.faqs ?? []),
];
---

<GeneratedPage {...data} jsonLd={jsonLd} />
