---
import { getCollection } from "astro:content";
import GeneratedPage from "../../components/GeneratedPage.astro";
import { breadcrumbListSchema, faqPageSchema } from "../../lib/schema";

const entries = await getCollection("use-cases");
const page = entries.find((e) => e.id === "generate-free-tools-as-code");
if (!page) throw new Error("generate-free-tools-as-code entry not found");
const { data } = page;

const jsonLd = [
  breadcrumbListSchema([
    { name: "Home", item: "/" },
    { name: "Use cases", item: "/use-cases/generate-free-tools-as-code" },
  ]),
  faqPageSchema(data.faqs ?? []),
];
---

<GeneratedPage {...data} jsonLd={jsonLd} />
