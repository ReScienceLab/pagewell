---
import { getCollection } from "astro:content";
import GeneratedPage from "../../components/GeneratedPage.astro";
import { articleSchema, breadcrumbListSchema, faqPageSchema } from "../../lib/schema";

const entries = await getCollection("use-cases");
const page = entries.find((e) => e.id === "generate-seo-pages-as-code");
if (!page) throw new Error("generate-seo-pages-as-code entry not found");
const { data } = page;

const jsonLd = [
  articleSchema({
    headline: data.title,
    description: data.description,
    url: data.canonical,
    keywords: ["generate SEO pages as code", "repo-native SEO", "SEO/GEO pages"],
  }),
  breadcrumbListSchema([
    { name: "Home", item: "/" },
    { name: "Use cases", item: "/use-cases/generate-seo-pages-as-code" },
  ]),
  faqPageSchema(data.faqs ?? []),
];
---

<GeneratedPage {...data} jsonLd={jsonLd} />
