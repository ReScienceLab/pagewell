---
import { getCollection } from "astro:content";
import GeneratedPage from "../../components/GeneratedPage.astro";
import { breadcrumbListSchema, faqPageSchema, softwareApplicationSchema } from "../../lib/schema";

const entries = await getCollection("products");
const page = entries.find((e) => e.id === "pagewell");
if (!page) throw new Error("pagewell entry not found");
const { data } = page;

const jsonLd = [
  softwareApplicationSchema(),
  breadcrumbListSchema([
    { name: "Home", item: "/" },
    { name: "Products", item: "/products/pagewell" },
  ]),
  faqPageSchema(data.faqs ?? []),
];
---

<GeneratedPage {...data} jsonLd={jsonLd} />
